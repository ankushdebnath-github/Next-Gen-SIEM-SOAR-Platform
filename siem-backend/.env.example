# ─────────────────────────────────────────────────────────────────────────────
# SIEM / SOAR Platform — Environment Configuration
# Copy this file to .env and fill in values before running the server.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
# Port the Express / Socket.io server listens on
PORT=5000

# Node environment: development | production | test
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# MongoDB connection string (Atlas or local)
# Local:  mongodb://127.0.0.1:27017/siem_soar
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/siem_soar?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017/siem_soar

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
# e.g. for multiple: http://localhost:4200,https://siem.yourdomain.com
CORS_ORIGIN=http://localhost:4200

# ── Threat Worker ─────────────────────────────────────────────────────────────
# Interval (in milliseconds) at which the worker generates new threat events
THREAT_INTERVAL_MS=800

# ── OSINT Enrichment ──────────────────────────────────────────────────────────
# VirusTotal v3 API key — get one free at https://www.virustotal.com/gui/my-apikey
VT_API_KEY=dac699d493c56a8d1fb3a8fa8950160f68446e71b7e54299bf2b78ee75ef0667

# Shodan API key — get one at https://account.shodan.io
SHODAN_API_KEY=0rhvDOephwwiJj0ysqSuUgjkeBnF4VvV

# Set to 'false' to use real API keys above. Default is 'true' (mock mode).
OSINT_MOCK=false
